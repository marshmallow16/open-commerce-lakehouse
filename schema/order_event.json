{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ONDC Order Event",
    "description": "Schema for raw order events on the ONDC network. Used for validation at Bronze ingestion boundary.",
    "type": "object",
    "required": ["order_id", "buyer_id", "seller_id", "product_id", "category", "quantity", "unit_price", "total_amount", "status", "event_ts"],
    "properties": {
        "order_id":     { "type": "string", "minLength": 1, "description": "Unique order identifier (UUID)" },
        "buyer_id":     { "type": "string", "minLength": 1 },
        "seller_id":    { "type": "string", "minLength": 1 },
        "seller_name":  { "type": "string" },
        "seller_city":  { "type": "string" },
        "product_id":   { "type": "string", "minLength": 1 },
        "product_name": { "type": "string" },
        "category":     { "type": "string", "enum": ["Electronics", "Fashion", "Grocery", "Home & Kitchen", "Books", "Health", "Sports"] },
        "quantity":     { "type": "integer", "minimum": 1 },
        "unit_price":   { "type": "number", "minimum": 0 },
        "total_amount": { "type": "number", "minimum": 0 },
        "status":       { "type": "string", "enum": ["CREATED", "CONFIRMED", "CANCELLED", "DELIVERED"] },
        "buyer_city":   { "type": "string" },
        "event_ts":     { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of the event" }
    },
    "additionalProperties": false
}
